{
  "name": "fancy-hn",
  "version": "1.0.0",
  "description": "A browser extension that replaces the Hacker News UI with a cleaner, more modern design.",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "BUILD_TARGET=content vite build --watch",
    "build": "BUILD_TARGET=content vite build && BUILD_TARGET=background vite build",
    "build:content": "BUILD_TARGET=content vite build",
    "build:background": "BUILD_TARGET=background vite build",
    "build:firefox": "BUILD_TARGET=content vite build --mode firefox && BUILD_TARGET=background vite build --mode firefox",
    "build:chromium": "BUILD_TARGET=content vite build --mode chromium && BUILD_TARGET=background vite build --mode chromium",
    "package:firefox": "./scripts/package-firefox.sh",
    "concepts:dev": "vite --config concepts/vite.config.ts",
    "concepts:build": "vite build --config concepts/vite.config.ts",
    "concepts:preview": "vite preview --config concepts/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "jsdom": "^29.0.1",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.3",
    "vue": "^3.5.31"
  }
}
